# ========================================
# 环境变量配置文件
# 复制此文件为 .env 并修改相应值
# ========================================

# DeepSeek API配置
DEEPSEEK_API_KEY=自己填
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Official Gemini API
GOOGLE_API_KEY=???
GEMINI_DEFAULT_ROUTE=google
GEMINI_ENABLE_OPENROUTER_FALLBACK=False

# OpenRouter API配置（对照记忆/专检功能使用）
OPENROUTER_API_KEY=自己填
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8001
DEBUG=False

# 云服务器公网IP（可选，用于显示访问地址）
# SERVER_IP=43.132.156.72

# 文件路径配置（可选，默认使用相对路径）
# UPLOAD_DIR=uploads
# OUTPUT_DIR=outputs
# TEMP_IMAGES_DIR=temp_images

# LibreOffice 配置（Linux 服务器建议显式指定）
LIBREOFFICE_PATH=/usr/bin/soffice

# 图片处理配置
TARGET_IMAGE_WIDTH=1080

# CORS配置（允许的源，用逗号分隔，* 表示允许所有）
ALLOWED_ORIGINS=*

