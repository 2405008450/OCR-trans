# ========================================
# 环境变量配置文件
# 复制此文件为 .env 并修改相应值
# ========================================

# DeepSeek API配置
DEEPSEEK_API_KEY=自己填
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Official Gemini API
GOOGLE_API_KEY=???
GEMINI_DEFAULT_ROUTE=google
GEMINI_ENABLE_OPENROUTER_FALLBACK=False
GEMINI_TIMEOUT_SECONDS=120

# OpenRouter API配置（对照记忆/专检功能使用）
OPENROUTER_API_KEY=自己填
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8001
DEBUG=False

# 云服务器公网IP（可选，用于显示访问地址）
# SERVER_IP=43.132.156.72

# 文件路径配置（可选，默认使用相对路径）
# UPLOAD_DIR=uploads
# OUTPUT_DIR=outputs
# TEMP_IMAGES_DIR=temp_images

# LibreOffice 配置（Linux 服务器建议显式指定）
LIBREOFFICE_PATH=/usr/bin/soffice

# 图片处理配置
TARGET_IMAGE_WIDTH=1080

# CORS配置（允许的源，用逗号分隔，* 表示允许所有）
ALLOWED_ORIGINS=*

# Queue tuning for single-process concurrent dispatch
TASK_QUEUE_MAX_CONCURRENT_TASKS=2
TASK_QUEUE_EXECUTOR_MAX_WORKERS=4
TASK_QUEUE_POLL_INTERVAL_SECONDS=0.5
TASK_QUEUE_CANDIDATE_BATCH_SIZE=20
# TASK_QUEUE_TYPE_LIMITS_JSON={"ocr":1,"pdf2docx":1,"msg_convert":1,"doc_translate":1,"alignment":1,"drivers_license":1,"business_licence":2,"number_check":2,"zhongfanyi":2}

# 字数统计：生产环境请配置局域网共享目录或服务器挂载目录白名单
# Windows 示例: ["\\\\win-server\\服务器资料7\\","\\\\win-server\\"]
# Linux 示例: ["/mnt/share/translation"]
# WORD_COUNT_ALLOWED_ROOTS_JSON=["\\\\win-server\\服务器资料7\\","\\\\win-server\\"]
# Docker 容器里不能直接读取 \\win-server\...；需要把 Windows Server 共享目录挂到容器内 Linux 路径。
# docker-compose.yml 已预留下面两个宿主机路径变量，并映射到容器内 /mnt/win-server/服务器资料7 和 /mnt/win-server/服务器资料3。
# Linux 宿主机示例：先 mount -t cifs //win-server/服务器资料7 /mnt/win-server/服务器资料7，再设置 WORD_COUNT_SHARE7_HOST_PATH=/mnt/win-server/服务器资料7
# Windows/Docker Desktop 示例：如果 Docker 能访问 UNC，可尝试 WORD_COUNT_SHARE7_HOST_PATH=//win-server/服务器资料7
# WORD_COUNT_SHARE7_HOST_PATH=/mnt/win-server/服务器资料7
# WORD_COUNT_SHARE3_HOST_PATH=/mnt/win-server/服务器资料3
# 最小可用配置示例：
# WORD_COUNT_SHARE7_HOST_PATH=/mnt/win-server/服务器资料7
# WORD_COUNT_ALLOWED_ROOTS_JSON=["\\\\win-server\\服务器资料7\\"]
# 精确映射可显式声明；不声明时也会自动尝试 /mnt/win-server/服务器资料7 这类容器路径。
# WORD_COUNT_UNC_MOUNT_MAP_JSON={"\\\\win-server\\服务器资料7\\":"/mnt/win-server/服务器资料7","\\\\win-server\\服务器资料3\\":"/mnt/win-server/服务器资料3","\\\\win-server\\":"/mnt/win-server"}
WORD_COUNT_UNC_AUTO_MOUNT_ROOTS_JSON=["/mnt","/media","/shares","/srv","/data","/app/data","/app/mnt","/app"]
# 测试阶段如需放开本机盘符，可设为 True；生产环境建议保持 False
WORD_COUNT_ALLOW_LOCAL_PATHS=False
WORD_COUNT_MAX_FILES=5000
WORD_COUNT_MAX_FILE_MB=200
WORD_COUNT_FOLLOW_SYMLINKS=False

# CAD 字数统计：Windows 会自动发现版本化安装目录；生产环境建议显式配置。
# Windows 示例: C:\Program Files\ODA\ODAFileConverter 27.1.0\ODAFileConverter.exe
# Linux/Docker 示例: /opt/oda/ODAFileConverter
# Linux 无图形桌面时建议同时安装 xvfb；程序也会尝试 Qt offscreen 模式。
# ODA_FILE_CONVERTER_PATH=C:\Program Files\ODA\ODAFileConverter 27.1.0\ODAFileConverter.exe
WORD_COUNT_CAD_CONVERT_TIMEOUT_SECONDS=300

# MSG 转 Word/PDF：单次请求总上传大小上限（MB）
MSG_CONVERT_UPLOAD_MAX_MB=95

